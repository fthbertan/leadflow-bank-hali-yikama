# LeadFlow — Blog URL Yönlendirmesi
# Blog detay sayfaları post.php üzerinden DB'den render edilir

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /blog/

    # Mevcut PHP dosyası, index.html ve template dosyalarına dokunma
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    RewriteRule ^index\.html$ - [L]
    RewriteRule ^blog-detail-template\.html$ - [L]
    RewriteRule ^blog-list-template\.html$ - [L]
    RewriteRule ^post\.php$ - [L]

    # /blog/slug veya /blog/slug.html → post.php (DB'den render)
    RewriteRule ^([a-z0-9-]+)\.html$ post.php?slug=$1 [L,QSA]
    RewriteRule ^([a-z0-9-]+)$ post.php?slug=$1 [L,QSA]
</IfModule>
