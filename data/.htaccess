# LeadFlow — data/ klasörü güvenlik kuralları
# JSON dosyalarına ve hassas verilere dışarıdan erişimi engelle

# Dizin listelemeyi kapat
Options -Indexes

# Tüm dosyalara erişimi engelle (PHP hariç — API üzerinden erişilir)
<FilesMatch "\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
